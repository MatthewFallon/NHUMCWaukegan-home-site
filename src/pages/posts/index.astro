---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const allPosts = await getCollection("blog")
---
<BaseLayout title="Events and News" >
    <iframe id="desktop-calendar" src="https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FChicago&showPrint=0&src=bmV3aG9wZXVtY3dhdWtlZ2FuQGdtYWlsLmNvbQ&color=%234285f4" style="border:solid 1px #777" width="100%" height="600" frameborder="0" scrolling="no"></iframe>
    <iframe id="mobile-calendar" src="https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FChicago&showPrint=0&mode=AGENDA&src=bmV3aG9wZXVtY3dhdWtlZ2FuQGdtYWlsLmNvbQ&color=%234285f4" style="border:solid 1px #777" width="100%" height="600" frameborder="0" scrolling="no"></iframe>
    <p>Events and news from our church.</p>
    <ul>
        {
            allPosts.map((post) => (
                <li>
                    <a href={`/posts/${post.id}`}>
                        <img src={post.data.image.url} alt={post.data.image.alt} />
                        <h2>{post.data.title}</h2>
                        <p>{post.data.description}</p>
                    </a>
                </li>
            ))
        }
    </ul>
</BaseLayout>

<style>
    #desktop-calendar {
        display: none;
    }

    @media (width > 1250px) {
        #desktop-calendar {
            display: unset;
        }
        
        #mobile-calendar {
            display: none;
        }
    }
    /* Card Displays per post */

    ul {
        padding: 0;
        display: grid;
        gap: 10px;
    }

    ul li {
        display: block;
    }

    ul li a {
        height: 100%;
        max-height: 400px;
        display: block;
        border-radius: 25px;
        border: 1px #777 solid;
        text-decoration: none;
    }

    ul li a:hover {
        background: #a0a0a020;
        border-color: #333;
    }

    ul li a img {
        max-height: 250px;
        height: 60%;
        width: 100%;
        object-fit: cover;
        border-radius: 25px 25px 0 0;
        display: block;
    }

    ul li a h2 {
        padding: 0 10px;
        margin-bottom: 0;
    }

    ul li a p {
        padding: 0 24px;
    }

    @media (width > 1250px) {
        ul {
        grid-template: auto / 1fr 1fr;

        }
    }
</style>